# LLM provider: "openai" (default) or "ollama"
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Logging
# File subscriber destination (used when FileSubscriber is registered)
LOG_FILE=./langgraph-glove.log


RPC_MODE=http

# Unix socket path (used when RPC_MODE=unix)
SOCKET_PATH=/tmp/langgraph-glove.sock

# HTTP tool server URL (used when RPC_MODE=http)
TOOL_SERVER_URL=http://localhost:3001

# HTTP tool server port (for tool-example)
PORT=3001

# BlueBubbles channel config
BLUEBUBBLES_URL=http://your-mac-ip:1234
BLUEBUBBLES_PASSWORD=yourpassword
BLUEBUBBLES_WEBHOOK_PORT=5001

# Web UI channel port
WEB_PORT=8080

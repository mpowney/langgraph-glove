{
  "cli": {
    "enabled": true,
    "settings": {
      "receiveAgentProcessing": false,
      "receiveSystem": false
    }
  },
  "web": {
    "enabled": true,
    "settings": {
      "host": "0.0.0.0",
      "port": 8080,
      "receiveAgentProcessing": true,
      "receiveSystem": true,
      "allowedUrlProtocols": ["sandbox://", "message://"]
    }
  },
  "bluebubbles": {
    "enabled": true,
    "settings": {
      "serverUrl": "{SECRET:bluebubbles-server-url}",
      "password": "{SECRET:bluebubbles-password}",
      "webhookHost": "0.0.0.0",
      "webhookPort": 5001,
      "receiveAgentProcessing": false,
      "receiveSystem": false,
      "conversationTtlMs": 1800000
    }
  },
  "observability": {
    "enabled": true,
    "settings": {
      "host": "0.0.0.0",
      "port": 8090,
      "receiveAgentProcessing": true,
      "receiveSystem": true
    }
  }
}

{
  "weather-au": {
    "transport": "unix-socket",
    "url": "http://localhost:3001",
    "socketName": "weather_au"
  },
  "weather-eu": {
    "transport": "unix-socket",
    "url": "http://localhost:3002",
    "socketName": "weather_eu"
  },
  "weather-us": {
    "transport": "unix-socket",
    "socketName": "weather_us"
  },
  "browse": {
    "transport": "unix-socket",
    "url": "http://localhost:3010",
    "socketName": "browse"
  },
  "browse-session": {
    "transport": "unix-socket",
    "url": "http://localhost:3011",
    "socketName": "browse-session"
  },
  "search": {
    "transport": "unix-socket",
    "url": "http://localhost:3012",
    "socketName": "search"
  },
  "memory": {
    "transport": "http",
    "url": "http://localhost:3013",
    "socketName": "memory",
    "enabled": true
  },
  "macos-control": {
    "transport": "http",
    "url": "{SECRET:macos-tool-endpoint}",
    "socketName": "macos-control",
    "enabled": true
  },
  "admin": {
    "transport": "unix-socket",
    "url": "http://localhost:3014",
    "socketName": "admin"
  },
  "datetime": {
    "transport": "unix-socket",
    "url": "http://localhost:3015",
    "socketName": "datetime"
  },
  "schedule": {
    "transport": "http",
    "url": "http://localhost:3016",
    "socketName": "schedule"
  },
  "config": {
    "transport": "unix-socket",
    "enabled": true,
    "socketName": "config"
  },
  "context-compression": {
    "transport": "unix-socket",
    "url": "http://localhost:3017",
    "socketName": "context-compression",
    "enabled": true
  },
  "docker": {
    "transport": "unix-socket",
    "url": "http://localhost:3018",
    "socketName": "docker",
    "enabled": true
  },
  "mcp-github": {
    "transport": "unix-socket",
    "socketName": "mcp-github",
    "enabled": false,
    "launcher": {
      "packageName": "@langgraph-glove/tool-mcp-client"
    },
    "mcp": {
      "endpoint": "http://localhost:3301/mcp",
      "toolNamePrefix": "mcp_github__",
      "auth": {
        "mode": "bearer-static",
        "token": "{SECRET:mcp-github-token}"
      }
    }
  },
  "mcp-atlassian": {
    "transport": "unix-socket",
    "socketName": "mcp-atlassian",
    "enabled": false,
    "launcher": {
      "packageName": "@langgraph-glove/tool-mcp-client"
    },
    "mcp": {
      "endpoint": "http://localhost:3302/mcp",
      "toolNamePrefix": "mcp_atlassian__",
      "auth": {
        "mode": "oauth-client-credentials",
        "tokenUrl": "https://example.com/oauth/token",
        "clientId": "{SECRET:mcp-atlassian-client-id}",
        "clientSecret": "{SECRET:mcp-atlassian-client-secret}",
        "scope": "read:all"
      }
    }
  },
  "imap-gmail": {
    "transport": "unix-socket",
    "socketName": "imap-gmail",
    "enabled": true,
    "launcher": {
      "packageName": "@langgraph-glove/tool-imap"
    },
    "imap": {
      "displayName": "Gmail",
      "server": {
        "host": "{SECRET:imap-gmail-host}",
        "port": 993,
        "secure": true,
        "tlsRejectUnauthorized": true,
        "auth": {
          "user": "{SECRET:imap-gmail-user}",
          "password": "{SECRET:imap-gmail-password}"
        }
      },
      "mailbox": "INBOX",
      "crawl": {
        "mode": "continuous-sync",
        "allFoldersExcept": ["Trash", "Spam", "Junk", "[Google Mail].All Mail"],
        "batchSize": 2000,
        "pollIntervalMs": 300000
      },
      "vector": {
        "embeddingModelKey": "imap-embed",
        "indexingStrategy": "immediate",
        "embeddingBatchSize": 4,
        "chunking": {
          "chunkSize": 900,
          "chunkOverlap": 140
        }
      },
      "attachment": {
        "enabled": true,
        "maxFileSizeBytes": 104857600,
        "parallelism": 2,
        "ocrModelKey": "imap-ocr-vision",
        "photoCaptionModelKey": "imap-photo-caption",
        "pdfMaxOcrPages": 8
      },
      "indexDbPath": "data/imap-gmail.sqlite",
      "urlTemplate": "https://mail.google.com/mail/u/0/#search/rfc822msgid%3A{messageId}"
    }
  },
  "imap-icloud": {
    "transport": "unix-socket",
    "socketName": "imap-icloud",
    "enabled": true,
    "launcher": {
      "packageName": "@langgraph-glove/tool-imap"
    },
    "imap": {
      "displayName": "iCloud",
      "server": {
        "host": "{SECRET:imap-icloud-host}",
        "port": 993,
        "secure": true,
        "tlsRejectUnauthorized": true,
        "auth": {
          "user": "{SECRET:imap-icloud-user}",
          "password": "{SECRET:imap-icloud-password}"
        }
      },
      "mailbox": "INBOX",
      "crawl": {
        "mode": "continuous-sync",
        "allFoldersExcept": ["Trash", "Spam", "Junk"],
        "batchSize": 2000,
        "pollIntervalMs": 300000
      },
      "vector": {
        "embeddingModelKey": "imap-embed",
        "indexingStrategy": "immediate",
        "embeddingBatchSize": 4,
        "chunking": {
          "chunkSize": 900,
          "chunkOverlap": 140
        }
      },
      "attachment": {
        "enabled": true,
        "maxFileSizeBytes": 104857600,
        "parallelism": 2,
        "ocrModelKey": "imap-ocr-vision",
        "photoCaptionModelKey": "imap-photo-caption",
        "pdfMaxOcrPages": 8
      },
      "indexDbPath": "data/imap-icloud.sqlite",
      "urlTemplate": "https://mail.icloud.com/mail/#folder/{folder}/{uid}"
    }
  }
}

{
  "name": "langgraph-glove",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm --filter @langgraph-glove/tool-server build && pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "start": "node packages/gateway/dist/main.js",
    "start:web": "node packages/gateway/dist/main.js --web",
    "start:web-only": "node packages/gateway/dist/main.js --web --no-cli",
    "debug": "pnpm exec tsx --inspect packages/gateway/src/main.ts",
    "debug:web": "pnpm exec tsx --inspect packages/gateway/src/main.ts --web",
    "debug:web-only": "pnpm exec tsx --inspect packages/gateway/src/main.ts --web --no-cli"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

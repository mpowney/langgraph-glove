{
  "name": "langgraph-glove",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm --filter @langgraph-glove/tool-server build && pnpm --filter @langgraph-glove/ui-observability build && pnpm -r typecheck",
    "backup:create": "node scripts/backup-workspace.mjs",
    "backup:restore": "node scripts/restore-workspace.mjs",
    "memory:smoke": "bash scripts/memory-smoke.sh",
    "memory:inspect": "node scripts/inspect-memories.cjs",
    "memory:inspect:personal": "node scripts/inspect-memories.cjs --personal",
    "memory:fix-paths": "node scripts/fix-memory-storage-paths.cjs",
    "tools:dev": "pnpm --filter @langgraph-glove/tool-manager dev",
    "tools:dev:tool": "pnpm --filter @langgraph-glove/tool-manager dev",
    "tools:dev:dry": "pnpm --filter @langgraph-glove/tool-manager exec tsx src/main.ts dry-run",
    "tools:stop": "pnpm --filter @langgraph-glove/tool-manager dev:stop",
    "tools:stop:tool": "pnpm --filter @langgraph-glove/tool-manager dev:stop",
    "clean": "pnpm -r clean",
    "start": "node packages/core/dist/main.js",
    "start:cli": "node packages/core/dist/main.js --cli",
    "debug": "pnpm exec tsx --inspect packages/core/src/main.ts",
    "debug:cli": "pnpm exec tsx --inspect packages/core/src/main.ts --cli",
    "ui:web": "pnpm --filter @langgraph-glove/ui-web dev",
    "ui:observability": "pnpm --filter @langgraph-glove/ui-observability dev",
    "macos:bundle": "bash scripts/macos-bundle-control-app.sh",
    "macos:bundle:open": "bash scripts/macos-bundle-control-app.sh --open"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

{
  "name": "@langgraph-glove/core",
  "version": "0.1.0",
  "description": "Core agent, channels, RPC clients and remote tool support for langgraph-glove",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/examples/cli.ts src/examples/cli-and-web.ts --format esm --dts --out-dir dist",
    "dev": "tsup src/index.ts src/examples/cli.ts src/examples/cli-and-web.ts --format esm --dts --out-dir dist --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "debug": "tsx --inspect src/examples/cli-and-web.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@langgraph-glove/config": "workspace:*",
    "@langgraph-glove/ui-web": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "express": "^4.21.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}

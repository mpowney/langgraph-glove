{
  "name": "@langgraph-glove/tool-manager",
  "version": "0.1.0",
  "description": "Interactive CLI manager for starting and supervising tool processes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/main.ts --format esm --dts --out-dir dist",
    "dev": "tsx src/main.ts run",
    "dev:stop": "tsx src/main.ts stop",
    "start": "node dist/main.js run",
    "stop": "node dist/main.js stop",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@langgraph-glove/config": "workspace:*",
    "blessed": "^0.1.81"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

{
  "name": "@langgraph-glove/tool-mcp-client",
  "version": "0.1.0",
  "description": "Remote tool package — MCP client bridge with per-instance auth configuration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/main.ts --format esm --dts --out-dir dist",
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@langgraph-glove/config": "workspace:*",
    "@langgraph-glove/tool-server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

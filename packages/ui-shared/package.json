{
  "name": "@langgraph-glove/ui-shared",
  "version": "0.1.0",
  "description": "Shared React UI components used by ui-web and tool panel companion packages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@fluentui/react-components": ">=9",
    "@fluentui/react-icons": ">=2",
    "react": ">=18"
  },
  "devDependencies": {
    "@fluentui/react-components": "^9.62.0",
    "@fluentui/react-icons": "^2.0.286",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.23",
    "react": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}

{
  "name": "@langgraph-glove/ui-web",
  "version": "0.1.0",
  "description": "React/Fluent UI v9 chat SPA for langgraph-glove WebChannel",
  "private": true,
  "type": "module",
  "main": "./dist/node/index.js",
  "types": "./dist/node/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/node/index.js",
      "types": "./dist/node/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsup src/node/index.ts --format esm --dts --out-dir dist/node --tsconfig tsconfig.node.json",
    "dev": "vite",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.node.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@langgraph-glove/tool-config-ui": "workspace:*",
    "@langgraph-glove/tool-imap-ui": "workspace:*",
    "@langgraph-glove/tool-memory-ui": "workspace:*",
    "@langgraph-glove/ui-shared": "workspace:*",
    "@fluentui/react-components": "^9.62.0",
    "@fluentui/react-icons": "^2.0.286",
    "@monaco-editor/react": "4.7.0",
    "@simplewebauthn/browser": "^13.3.0",
    "monaco-editor": "0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}

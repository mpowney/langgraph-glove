{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@langgraph-glove/ui-shared": ["../ui-shared/src/index.ts"],
      "@langgraph-glove/tool-imap-ui/meta": ["../tool-imap-ui/src/meta.ts"],
      "@langgraph-glove/tool-memory-ui/meta": ["../tool-memory-ui/src/meta.ts"],
      "@langgraph-glove/tool-config-ui/meta": ["../tool-config-ui/src/meta.ts"],
      "@langgraph-glove/tool-imap-ui": ["../tool-imap-ui/src/index.tsx"],
      "@langgraph-glove/tool-memory-ui": ["../tool-memory-ui/src/index.tsx"],
      "@langgraph-glove/tool-config-ui": ["../tool-config-ui/src/index.tsx"]
    },
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": ["src/node", "node_modules", "dist"]
}
